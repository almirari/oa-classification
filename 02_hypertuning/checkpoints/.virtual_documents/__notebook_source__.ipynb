    print(f"  {'Mean':<6}  {np.mean(qwks):>8.4f}  {np.mean(accs):>9.2f}%  "
          f"{np.mean([r['rmse'] for r in results]):>8.4f}  "
          f"{np.mean([r['mae'] for r in results]):>8.4f}")
    print(f"  {'Std':<6}  {np.std(qwks):>8.4f}  {np.std(accs):>9.2f}%")

